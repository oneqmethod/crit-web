# Required
DATABASE_URL=ecto://USER:PASS@HOST/DATABASE
SECRET_KEY_BASE=change-me-generate-with-openssl-rand-base64-64

# Self-hosted mode (enables dashboard, disables marketing pages)
SELFHOSTED=true

# Admin dashboard password (optional — if unset, dashboard is accessible without auth)
# ADMIN_PASSWORD=your-secure-password

# Host configuration
PHX_HOST=localhost
PORT=4000

# URL generation (for links in the app)
# PHX_SCHEME=https
# PHX_URL_PORT=443

# Set to "true" to force HTTPS redirects
# Only needed if the app terminates TLS itself (not behind a reverse proxy)
# FORCE_SSL=false

# Optional
# POOL_SIZE=10
# ECTO_IPV6=false
